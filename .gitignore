# Segredos e tokens — NUNCA commitar
.mcp.json
*.env
.env.*
google_service_account.json
*service_account*.json
*.pem
*.key

# Documentos antigos com dados sensíveis — NUNCA commitar
"DOCUMENTOS ANTIGOS - AVALIAR E MIGRAR/"
DOCUMENTOS ANTIGOS*
DOCUMENTOS-ANTIGOS*

# Archive (legado local, reversível, caminhos longos) — não versionar
archive/

# Pastas do sistema
.claude/settings.local.json
mnt/

# Outputs gerados (não versionar arquivos de clientes)
output/propostas/*.docx
output/roteiros/*.docx
output/relatorios/*.docx
output/conteudo/*.docx

# Obsidian — estado de janela muda a cada abertura, não faz sentido versionar
cerebro/**/workspace.json

# Plugins Obsidian instalados como source (têm .git/ próprio — evitar conflito)
cerebro/**/.obsidian/plugins/hangarx/
cerebro/**/.obsidian/plugins/obsidian-3d-graph/
cerebro/**/.obsidian/plugins/advanced-canvas/

# Clone local do GitHub — não versionar dentro do repo
ORACULO-DA-FIRMA/

# Next.js — cache e build (não versionar)
oraculo-app/.next/
oraculo-app/node_modules/

# ECC — arquivos de runtime (não versionar)
.claude/scheduled_tasks.lock
.claude/ecc/session-data/
.claude/ecc/metrics/
.claude/ecc/session-aliases.json

# Vault — arquivos de trabalho nao sao versionados (usar Google Drive)
cerebro/**/*.xlsx
cerebro/**/*.ods
cerebro/**/*.docx
cerebro/**/*.doc
cerebro/**/*.odp
cerebro/**/*.bak
cerebro/**/*.pdf

# Vault — artifacts gerados por plugins Obsidian
cerebro/**/graphify-out/
cerebro/**/*.html

# Temporários
*.tmp
*.log
Thumbs.db
.DS_Store
