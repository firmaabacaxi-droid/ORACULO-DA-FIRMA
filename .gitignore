# Segredos e tokens — NUNCA commitar
.mcp.json
*.env
.env.*

# Documentos antigos com dados sensíveis — NUNCA commitar
"DOCUMENTOS ANTIGOS - AVALIAR E MIGRAR/"
DOCUMENTOS ANTIGOS*
DOCUMENTOS-ANTIGOS*

# Archive (legado local, reversível, caminhos longos) — não versionar
archive/

# Pastas do sistema
.claude/settings.local.json
mnt/

# Outputs gerados (não versionar arquivos de clientes)
output/propostas/*.docx
output/roteiros/*.docx
output/relatorios/*.docx
output/conteudo/*.docx

# Obsidian — estado de janela muda a cada abertura, não faz sentido versionar
cerebro/**/workspace.json

# Clone local do GitHub — não versionar dentro do repo
ORACULO-DA-FIRMA/

# ECC — arquivos de runtime (não versionar)
.claude/scheduled_tasks.lock
.claude/ecc/session-data/
.claude/ecc/metrics/
.claude/ecc/session-aliases.json

# Temporários
*.tmp
*.log
Thumbs.db
.DS_Store
